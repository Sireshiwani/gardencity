# Copy to ".env" for local development only. Do not commit .env.
#
# DigitalOcean App Platform — database connection (pick ONE approach):
#
# 1) Bindable (recommended): on your WEB SERVICE component → Environment Variables:
#    Key: DATABASE_URL
#    Value: ${YOUR_DB_COMPONENT_NAME.DATABASE_URL}
#    Use the exact database component name from the app (Settings → Resources; the DB resource name).
#    Scope: RUN_AND_BUILD_TIME (needed if migrate runs during build/release).
#    If the value shows literally "${db.DATABASE_URL}" in Console → echo $DATABASE_URL, the bindable
#    did NOT resolve — fix the name (e.g. try ${postgres-db.DATABASE_URL}) or re-add the variable
#    in the UI (DO bulk editor can leave bindables unreplaced).
#
# 2) Literal URL (encrypted): paste the full postgresql://... string as DATABASE_URL.
#
# 3) Discrete bindables (when DATABASE_URL stays broken in the dashboard):
#    POSTGRES_USER=${YOUR_DB_NAME.USERNAME}
#    POSTGRES_PASSWORD=${YOUR_DB_NAME.PASSWORD}
#    POSTGRES_HOST=${YOUR_DB_NAME.HOSTNAME}
#    POSTGRES_PORT=${YOUR_DB_NAME.PORT}
#    POSTGRES_DB=${YOUR_DB_NAME.DATABASE}
#    Then DELETE the DATABASE_URL variable if it is empty or literal ${...} (stops DO validation errors).
#    Optional: POSTGRES_SSLMODE=require
#
# Repo must NOT contain runtime.txt (deprecated on DO). Only .python-version (e.g. 3.11).

# DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/defaultdb?sslmode=require

# DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=dev-only-change-me
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# If SSL errors with a local Postgres tunnel, try:
# DATABASE_SSL_REQUIRE=false
